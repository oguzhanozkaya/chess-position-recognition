# Reproducible generated data. Keep only directory placeholders.
data/*
!data/raw/
!data/interim/
!data/processed/
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Generated model outputs and reports. Keep only directory placeholders.
output/*
!output/figures/
!output/models/
!output/predictions/
!output/reports/
output/figures/*
output/models/*
output/predictions/*
output/reports/*
!output/figures/.gitkeep
!output/models/.gitkeep
!output/predictions/.gitkeep
!output/reports/.gitkeep
